<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_weather_gradient"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Weather Forecast"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white"
        android:elevation="0dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="100dp"
                android:visibility="gone"
                android:indeterminateTint="@android:color/white" />

            <!-- Weather Content -->
            <LinearLayout
                android:id="@+id/weatherContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Main Weather Card with Custom Canvas View -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="12dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="@android:color/transparent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Custom Canvas Background -->
                        <com.example.securehomeplus.view.weather.WeatherCardView
                            android:id="@+id/weatherCardView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <!-- Content Overlay -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="24dp">

                            <TextView
                                android:id="@+id/tvLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loading..."
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:fontFamily="@font/poppins_bold"
                                android:shadowColor="#80000000"
                                android:shadowDx="2"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                            <ImageView
                                android:id="@+id/ivWeatherIcon"
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:src="@drawable/ic_weather_sunny"
                                android:layout_marginVertical="8dp"
                                app:tint="@android:color/white"
                                android:alpha="0.95" />

                            <TextView
                                android:id="@+id/tvTemperature"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--&#176;C"
                                android:textSize="56sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:fontFamily="@font/poppins_bold"
                                android:shadowColor="#CC000000"
                                android:shadowDx="4"
                                android:shadowDy="4"
                                android:shadowRadius="8"
                                android:background="@drawable/temp_background"
                                android:paddingHorizontal="20dp"
                                android:paddingVertical="4dp" />

                            <TextView
                                android:id="@+id/tvDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textColor="@android:color/white"
                                android:fontFamily="@font/poppins_medium"
                                android:layout_marginTop="4dp"
                                android:alpha="0.9" />

                            <TextView
                                android:id="@+id/tvFeelsLike"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Feels like --&#176;C"
                                android:textSize="16sp"
                                android:textColor="@android:color/white"
                                android:layout_marginTop="8dp"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- Weather Details Grid with Animations -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <!-- Humidity Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardHumidity"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_humidity"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvHumidityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Humidity"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Wind Speed Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardWind"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_wind"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvWindValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- m/s"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wind Speed"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Second Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <!-- Pressure Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPressure"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_pressure"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvPressureValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- hPa"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pressure"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Visibility Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardVisibility"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_visibility"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvVisibilityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- km"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Visibility"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Sun Times Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSunTimes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:backgroundTint="@android:color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/sunrise_background"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/ic_sunrise"
                                app:tint="#FF9800"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:id="@+id/tvSunrise"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--:--"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sunrise"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>

                        <View
                            android:layout_width="2dp"
                            android:layout_height="100dp"
                            android:background="@drawable/divider_gradient" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/sunset_background"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/ic_sunset"
                                app:tint="#FF5722"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:id="@+id/tvSunset"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--:--"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#FF5722"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sunset"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Temperature Range Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTempRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:backgroundTint="@android:color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_temp_min"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvTempMin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--&#176;C"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Min Temp"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_temp_max"
                                app:tint="@color/teal_700"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tvTempMax"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--&#176;C"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_700"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max Temp"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:fontFamily="@font/poppins_regular" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Refresh Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Refresh Weather"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/teal_700"
                    android:fontFamily="@font/poppins_medium"
                    app:cornerRadius="16dp"
                    android:paddingVertical="14dp"
                    android:elevation="8dp" />
            </LinearLayout>

            <!-- Error Layout -->
            <LinearLayout
                android:id="@+id/errorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="32dp"
                android:layout_marginTop="100dp">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_error"
                    app:tint="@android:color/white"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.8" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Failed to load weather"
                    android:textSize="18sp"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
